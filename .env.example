# Claude API key (get it from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Twitter/X credentials for twikit
# You can use either username/password OR cookies (recommended)
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=

# Optional: favorite users to track (comma-separated, without @)
FAVORITE_USERS=elonmusk,sama,karpathy

# Password to protect the app when exposed to the Internet.
# Leave empty to disable authentication (local use only).
APP_PASSWORD=

# Directory for persistent data (data.db, cookies.json, favorites.json).
# Defaults to the project root. Set to /data in Docker.
# DATA_DIR=/data
