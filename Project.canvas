		{"id":"group-adapta","type":"group","x":2730,"y":1744,"width":540,"height":2240,"label":"Adaptación Móvil"},
		{"id":"group-setup","type":"group","x":1620,"y":40,"width":1030,"height":974,"label":"Setup"},
