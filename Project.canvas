		{"id":"group-acceso","type":"group","x":1620,"y":1084,"width":540,"height":920,"label":"Acceso a Datos"},
		{"id":"group-motori","type":"group","x":1620,"y":2074,"width":540,"height":920,"label":"Motor IA"},
